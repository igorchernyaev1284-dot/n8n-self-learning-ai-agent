    {
      "parameters": {
        "jsCode": "// Получаем текст сообщения\nconst msg = $input.item.json?.message?.text || \"\";\nconst chatType = $input.item.json?.message?.chat?.type || \"\";\nconst isBot = $input.item.json?.message?.from?.is_bot || false;\n\n// Фильтр базовый: только группы, не боты, текст > 6 символов\nif (![\"group\", \"supergroup\"].includes(chatType) || isBot || msg.length < 6) {\n  return [];  // пустой массив = дальше не идёт\n}\n\n// Проверка на вопросительные слова (регулярка без учёта регистра)\nconst questionWords = /(^|\\s)(как|что|почему|зачем|когда|где|сколько|можно|нужно|покажи|объясни|подскажи|расскажи|дай|помоги|есть\\sли|можете\\sли)(\\s|$|\\?)/i;\nconst hasQuestionMark = msg.includes(\"?\");\nconst hasQuestionWord = questionWords.test(msg);\n\n// Если хоть одно условие сработало — это вопрос\nif (hasQuestionMark || hasQuestionWord) {\n  return [$input.item];  // передаём дальше\n} else {\n  return [];  // не вопрос — останавливаем\n}\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [688, 0],
      "id": "953ed1bc-bd6a-4567-9739-b5b5453407e0",
      "name": "Is Is Question"
    },
    {
      "parameters": {
        "jsCode": "// Разбор ответа ИИ\nconst raw = $input.item.json?.output || \"\";\nlet data = { confidence: 0, answer: \"\", links: [] };\n\ntry {\n  data = JSON.parse(raw);\n} catch (e) {\n  data = { confidence: 0, answer: \"\", links: [] };\n}\n\nreturn [{ ...data, raw_output: raw }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1216, 0],
