    },
    {
      "parameters": {
        "jsCode": "const inputData = $input.first().json;\nconst text = `${inputData.question}\\n\\nОтвет: ${inputData.answer}`;\nconst metadata = {\n  source: \"expert\",\n  created_at: new Date().toISOString(),\n  question: inputData.question,\n  answer: inputData.answer,\n  lang: \"ru\",\n  ticketId: inputData.ticketId\n};\n\nreturn [{\n  json: {\n    text,\n    metadata\n  }\n}];\n"
      },
