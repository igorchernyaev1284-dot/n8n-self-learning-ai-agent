    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nif (!staticData.tickets) {\n  staticData.tickets = [];\n}\n\nconst triggerData = $('Is Is Question').item.json;\nif (!triggerData || !triggerData.message) {\n  return [{ json: { cardText: '', ticketId: '', chatId: '', parseMode: 'HTML' } }];\n}\nconst message = triggerData.message;\nconst question = message.text || 'Нет вопроса';\nconst chatId = message.chat ? message.chat.id : 'Нет ID';\nconst msgId = message.message_id || 0;\nconst ticketId = `${Date.now()}_${msgId}`;\nconst userHandle = message.from?.username ? `@${message.from.username}` : (message.from?.first_name || 'Unknown');\nconst expertChatId = \"YOUR_EXPERT_CHAT_ID\"; // Сюда подставить ID чата эксперта\n\nstaticData.tickets.push({\n  question: question,\n  chatId: chatId,\n  expertChatId: expertChatId,\n  msgId: msgId,\n  status: 'open',\n  ticketId: ticketId\n});\n\nconst cardText = `🆘 Новый вопрос:\\n\\n<b>${question}</b>\\n\\nОт: ${userHandle}\\n\\nИНСТРУКЦИЯ: Нажми долгим нажатием на это сообщение > Выбери \"Reply\" (Ответить) > Напиши свой ответ текстом и отправь.`;\n\nconsole.log('Build Expert Card: СОЗДАЛ тикет', {ticketId, chatId, cardText});\n\nreturn [{\n  json: {\n    cardText,\n    ticketId,\n    chatId,\n    expertChatId,\n    parseMode: 'HTML',\n    msgIdGroup: msgId \n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2032, 80],
      "id": "a3ebd489-f59b-4dc9-b3bf-bc362ea3a549",
      "name": "Build Expert Card"
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst inputData = $input.first().json;\nconst message = inputData.message;\nconst answerText = message?.text || message?.caption || '';\n\nif (!answerText) {\n  return [{ json: { question: '', answer: 'Нет ответа', chatId: '', msgId: 0 } }];\n}\n\nconst msgIdGroup = message.reply_to_message ? message.reply_to_message.message_id : 0;\n\nconsole.log('Match Answer to Ticket: ищем по msgIdGroup:', msgIdGroup);\n\nconst matchedTicket = (staticData.tickets || []).find(t =>\n  t.msgId == msgIdGroup && t.status === 'open'\n);\n\nconsole.log('Match Answer to Ticket: найденный тикет:', matchedTicket);\n\nif (matchedTicket) {\n  matchedTicket.answer = answerText;\n  matchedTicket.status = 'closed';\n  return [{\n    json: {\n      question: matchedTicket.question,\n      answer: answerText,\n      chatId: matchedTicket.chatId,\n      msgId: matchedTicket.msgId,\n      ticketId: matchedTicket.ticketId,\n    }\n  }];\n} else {\n  return [{\n    json: {\n      question: '',\n      answer: answerText,\n      chatId: '',\n      msgId: 0\n    }\n  }];\n}\n"
      },
